# Security for cron trigger
CRON_SECRET=replace_with_strong_secret

# Telegram
TELEGRAM_BOT_TOKEN=replace_with_bot_token
TELEGRAM_CHAT_ID=@your_telegram_channel_or_chat_id

# WhatsApp Cloud API (Meta)
WHATSAPP_ACCESS_TOKEN=replace_with_meta_access_token
WHATSAPP_PHONE_NUMBER_ID=replace_with_phone_number_id
WHATSAPP_RECIPIENTS=919999999999,918888888888
WHATSAPP_GRAPH_VERSION=v22.0

# Deals feed configuration
DEAL_FEEDS=https://slickdeals.net/newsearch.php?searcharea=deals&searchin=first&rss=1,https://www.reddit.com/r/buildapcsales/.rss
DAILY_DEALS_LIMIT=8
MIN_DISCOUNT_PERCENT=60
THIRTY_DAY_LOW_EPSILON=0.5

# Amazon Product Advertising API (optional but recommended)
AMAZON_PAAPI_ACCESS_KEY=your_paapi_access_key
AMAZON_PAAPI_SECRET_KEY=your_paapi_secret_key
AMAZON_PAAPI_PARTNER_TAG=youramazontag-21
AMAZON_PAAPI_HOST=webservices.amazon.in
AMAZON_PAAPI_REGION=eu-west-1
AMAZON_PAAPI_MARKETPLACE=www.amazon.in
AMAZON_KEYWORDS=laptop,headphones,smartphone

# Affiliate link settings
AMAZON_AFFILIATE_TAG=youramazontag-21
FLIPKART_AFFILIATE_ID=your_flipkart_affiliate_id
AFFILIATE_QUERY_PARAMS=utm_source=telegram&utm_medium=daily_deals
# Optional redirect wrapper endpoint for click tracking
# AFFILIATE_REDIRECT_BASE=https://yourdomain.com/go

# Optional: for persistent dedupe (recommended)
VERCEL_KV_URL=https://your-kv-store.upstash.io
VERCEL_KV_REST_API_TOKEN=your_kv_rest_token

NODE_ENV=production
